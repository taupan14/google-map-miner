{
  "name": "map-miner",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && uvicorn app.main:app --reload --port 8000",
    "dev:worker": "cd worker && python -m worker.main",
    "install:all": "npm install && cd backend && pip install -r requirements.txt && cd ../worker && pip install -r requirements.txt"
  },
  "allowScripts": {
    "unrs-resolver@1.12.2": true,
    "fsevents@2.3.3": true
  }
}
